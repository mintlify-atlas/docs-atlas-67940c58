  "publicApiSurface": [
    "GET /peliculas - List all movies",
    "GET /peliculas/{titulo} - Get movie by title",
    "POST /peliculas - Create new movie",
    "PUT /peliculas/{id} - Update movie",
    "DELETE /peliculas/{id} - Delete movie",
    "GET /obras - List all theater works",
    "POST /obras - Create new theater work",
    "GET /eventos-urbanos - List all urban events",
    "POST /eventos-urbanos - Create new urban event",
    "GET /artistas - List all artists",
    "POST /artistas - Create new artist",
    "GET /categorias - List all categories",
    "POST /categorias - Create new category",
    "GET /participaciones - List all participations",
    "POST /participaciones - Create new participation"
